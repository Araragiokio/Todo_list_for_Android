EXPO_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# Required when testing Google sign-in in Expo Go.
# Replace with your Expo account/project full name, then register the matching
# https://auth.expo.io/@your-expo-username/TodoApp/callback URI in Google Cloud.
EXPO_PUBLIC_EXPO_PROJECT_FULL_NAME=@your-expo-username/TodoApp

# Optional override. Use this if the console log says a different redirect URI is being used.
# EXPO_PUBLIC_GOOGLE_OAUTH_REDIRECT_URI=https://auth.expo.io/@your-expo-username/TodoApp/callback
